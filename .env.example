# Used ONLY by `npm run ingest` (Node script). Never shipped to the browser.
# Optional: with no key, ingest falls back to FRED's public fredgraph.csv endpoint.
FRED_API_KEY=

# Optional: market-data provider for the ingest snapshot (copper, ags, instrument
# presets). Default provider is Yahoo Finance's public chart API (no key needed).
# Set MARKET_PROVIDER=stooq to use Stooq instead.
MARKET_PROVIDER=yahoo
